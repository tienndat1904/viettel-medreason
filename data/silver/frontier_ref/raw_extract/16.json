[
  {"text": "Ung thư biểu mô tuyến đại tràng", "type": "CHẨN_ĐOÁN"},
  {"text": "bệnh phổi tắc nghẽn mạn tính, không xác định", "type": "CHẨN_ĐOÁN"},
  {"text": "Đái tháo đường", "type": "CHẨN_ĐOÁN"},
  {"text": "xơ gan do rượu", "type": "CHẨN_ĐOÁN"},
  {"text": "Viêm phổi bệnh viện", "type": "CHẨN_ĐOÁN"},
  {"text": "rung nhĩ", "type": "CHẨN_ĐOÁN"},
  {"text": "nhịp nhanh trên thất", "type": "CHẨN_ĐOÁN"},
  {"text": "xẹp phổi thùy dưới phải do chèn ép", "type": "CHẨN_ĐOÁN"},
  {"text": "tràn dịch màng phổi", "type": "CHẨN_ĐOÁN"},
  {"text": "tụt huyết áp", "type": "TRIỆU_CHỨNG"},
  {"text": "mệt mỏi", "type": "TRIỆU_CHỨNG"},
  {"text": "khó khăn khi ra khỏi giường", "type": "TRIỆU_CHỨNG"},
  {"text": "đau bụng gián đoạn", "type": "TRIỆU_CHỨNG"},
  {"text": "khó thở khi gắng sức", "type": "TRIỆU_CHỨNG"},
  {"text": "ho mạn tính có đờm vàng loãng", "type": "TRIỆU_CHỨNG"},
  {"text": "chán ăn", "type": "TRIỆU_CHỨNG"},
  {"text": "hạ huyết áp, không đặc hiệu", "type": "TRIỆU_CHỨNG"},
  {"text": "buồn nôn", "type": "TRIỆU_CHỨNG"},
  {"text": "nôn", "type": "TRIỆU_CHỨNG"},
  {"text": "tiêu chảy", "type": "TRIỆU_CHỨNG"},
  {"text": "táo bón", "type": "TRIỆU_CHỨNG"},
  {"text": "đau bụng", "type": "TRIỆU_CHỨNG"},
  {"text": "sốt", "type": "TRIỆU_CHỨNG"},
  {"text": "đau ngực", "type": "TRIỆU_CHỨNG"},
  {"text": "chóng mặt", "type": "TRIỆU_CHỨNG"},
  {"text": "đánh trống ngực", "type": "TRIỆU_CHỨNG"},
  {"text": "đỏ da", "type": "TRIỆU_CHỨNG"},
  {"text": "ran nổ", "type": "TRIỆU_CHỨNG"},
  {"text": "phù phù", "type": "TRIỆU_CHỨNG"},
  {"text": "huyết khối", "type": "TÊN_XÉT_NGHIỆM"},
